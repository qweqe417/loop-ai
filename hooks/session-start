#!/usr/bin/env bash
# SessionStart hook for AI Coding Loop plugin
#
# 注入 using-ai-coding-loop bootstrap skill 到 AI context（每次会话）
#
# 适配 Claude Code / Codex / Cursor / Copilot CLI

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# ── 读取 bootstrap skill ──
using_aicode_content=$(cat "${PLUGIN_ROOT}/skills/using-ai-coding-loop/SKILL.md" 2>&1 || echo "Error reading using-ai-coding-loop skill")

# ── JSON 转义 ──
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

using_aicode_escaped=$(escape_for_json "$using_aicode_content")
session_context="<EXTREMELY_IMPORTANT>\nYou have AI Coding Loop superpowers.\n\n**Below is the full content of your 'ai-coding-loop:using-ai-coding-loop' skill - your introduction to using skills. For all other AI Coding Loop skills, use the 'Skill' tool:**\n\n${using_aicode_escaped}\n</EXTREMELY_IMPORTANT>"

# ── Step 3: 输出 context injection JSON ──
# 平台适配（参考 superpowers）:
#   Cursor:       additional_context (snake_case)
#   Claude Code:  hookSpecificOutput.additionalContext (nested)
#   Copilot CLI:  additionalContext (top-level camelCase, SDK standard)
#   Codex/其他:   additionalContext (SDK standard)

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
    printf '{\n  "additional_context": "%s"\n}\n' "$session_context" | cat
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
    printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context" | cat
else
    printf '{\n  "additionalContext": "%s"\n}\n' "$session_context" | cat
fi

exit 0
